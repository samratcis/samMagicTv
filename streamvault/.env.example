# SamMagicTV display name
VITE_APP_NAME=SamMagicTV

# Cloudflare Worker URL for catalog, proxy, stream, and Stalker APIs.
# Local dev default is http://localhost:8787 when omitted.
VITE_WORKER_URL=http://localhost:8787

# Optional overrides. Leave unset for normal Cloudflare Worker-only builds.
# VITE_PROXY_URL=https://your-worker.your-subdomain.workers.dev
# VITE_CATALOG_URL=https://your-worker.your-subdomain.workers.dev
# VITE_STREAM_PROXY_URL=https://your-worker.your-subdomain.workers.dev
